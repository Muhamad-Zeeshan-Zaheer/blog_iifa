<%# articles index page %>
<h1>Articles</h1>
<div class="mb-3 text-end me-3">
  <%= link_to "New Article", new_article_path, class: "btn btn-primary" %>
</div>

<div class="container">
  <div class="row">
    <% @categories.each do |category| %>
      <div class="col-md-4 mb-4">
        <div class="card">
          <div class="card-body">
            <h5 class="card-title"><%= category.title %></h5>
            <p class="card-text">
              <%= category.articles.count %> articles
            </p>
            <%= link_to "View Articles", articles_category_path(category), class: "btn btn-primary" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
