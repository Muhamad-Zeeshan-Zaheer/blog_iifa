<%# articles index page %>
<h1>Articles</h1>
<div class="mb-3 text-end me-3">
  <%= link_to "New Article", new_article_path, class: "btn btn-primary" %>
</div>
<table class="table">
  <thead>
    <tr>
      <th scope="col">Title</th>
      <th scope="col">Description</th>
      <th scope="col">Action</th>
    </tr>
  </thead>
  <tbody>
    <% @articles.each do |article| %>
      <% unless article.archived? %>
      <tr>
        <td><%= article.title %></td>
        <td><%= article.body %></td>
        <td>
          <%= link_to "Show Article", article_path(article), class: "btn btn-success" %>
          <%= link_to "Edit Article", edit_article_path(article), class: "btn btn-warning" %>
          <%= link_to "Delete Article", article_path(article),data:{
            turbo_method: :delete,
            turbo_confirm: "Are you sure want to delete the article?"
          }, class: "btn btn-danger" %>
        </td>
      </tr>
      <% end %>
    <% end %>
  </tbody>
</table>
