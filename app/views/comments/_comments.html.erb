<div id="comments" data-article-id="<%= @article.id %>">
  <table class="table">
    <thead>
      <tr>
        <th>Title</th>
        <th>Body</th>
        <th>Actions</th>
      </tr>
    </thead>

    <tbody>
      <% @article.comments.each do |comment| %>
        <% unless comment.archived? %>
        <tr>
          <td><%= comment.title %></td>
          <td><%= comment.body %></td>
          <td>...</td>
        </tr>
        <% end %>
      <% end %>
    </tbody>
  </table>
</div>
